# Base URL della REST custom del WordPress headless.
# Dev (LocalWP): http://mediaaptitude.local/wp-json/mediaaptitude/v1
# Prod (Aruba, WP resta su root, Astro davanti via .htaccess): https://www.media-aptitude.it/wp-json/mediaaptitude/v1
WP_API_URL=http://mediaaptitude.local/wp-json/mediaaptitude/v1

# Google Places API — recensioni Google importate a BUILD-TIME (opzionale).
# Serve un progetto Google Cloud con Places API attiva e fatturazione abilitata.
# Il Place ID (pubblico) va in src/data/site.ts (google.placeId); la key resta qui.
# Se vuota, le recensioni non vengono caricate e la sezione resta nascosta.
GOOGLE_PLACES_API_KEY=

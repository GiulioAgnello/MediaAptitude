---
// Font self-hosted (@fontsource): solo i pesi usati e solo il subset latino
// (copre l'italiano à è é ì ò ù). Vite li impacchetta con hash + cache lunga;
// @font-face usa font-display: swap.
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter-tight/latin-500.css';
import '@fontsource/inter-tight/latin-600.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import CookieConsent from '../components/CookieConsent.astro';
import FloatingContact from '../components/FloatingContact.astro';
import { site } from '../data/site';
import { getSeo } from '../lib/api';
import { parseYoast } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  noindex?: boolean;
  /** Schemi JSON-LD specifici della pagina (vedi Seo.astro). */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, path = '/', noindex, schema } = Astro.props;

// SEO da WordPress (Yoast) per questo path, a build-time.
// Se WP è offline o non ha dati, parseYoast torna null → restano i default.
const wpSeo = parseYoast(await getSeo(path));
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    {/* View Transitions: navigazione SPA con cross-fade (feel app, niente flash). */}
    <ClientRouter />

    {/* Font self-hosted via @fontsource (import nel frontmatter).
        Nessuna connessione esterna a Google: meglio per latenza e privacy. */}

    {/* Tema: settato PRIMA del paint per evitare flash. Default dark (identità
        brand); se l'utente ha già scelto, si legge da localStorage. */}
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var t = localStorage.getItem('theme');
            document.documentElement.setAttribute('data-theme', t === 'light' ? 'light' : 'dark');
          } catch (e) {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        }
        applyTheme();
        // Ri-applica il tema dopo ogni transizione di pagina (ClientRouter).
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <Seo title={title} description={description} path={path} noindex={noindex} schema={schema} wpSeo={wpSeo} />

    {/* Reveal allo scroll: fallback per browser senza animation-timeline nativo.
        Su Chrome/Edge esce subito (usa la via CSS pura). Aggiunge .io-reveal
        prima del paint per evitare flash, poi attiva un IntersectionObserver. */}
    <script is:inline>
      (function () {
        try {
          var nativeOk = window.CSS && CSS.supports && CSS.supports('animation-timeline: view()');
          if (nativeOk) return;
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          document.documentElement.classList.add('io-reveal');
          function run() {
            var io = new IntersectionObserver(function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
              });
            }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
            document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach(function (el) { io.observe(el); });
          }
          // Su ogni pagina (iniziale + dopo ogni transizione).
          document.addEventListener('astro:page-load', run);
        } catch (err) {}
      })();
    </script>
  </head>
  <body>
    <div class="aurora" aria-hidden="true" transition:persist></div>
    <a href="#main" class="skip-link">Salta al contenuto</a>
    <Header transition:persist />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <BottomNav transition:persist />
    <FloatingContact transition:persist />
    <CookieConsent transition:persist />

    {/* Aggiorna l'active della bottom bar e chiude il menu dopo ogni transizione. */}
    <script is:inline>
      document.addEventListener('astro:page-load', function () {
        var p = location.pathname;
        document.querySelectorAll('.bottomnav__link').forEach(function (a) {
          var href = a.getAttribute('href') || '';
          var active = href === '/' ? p === '/'
            : (href.charAt(0) === '/' && href.indexOf('#') === -1 && p.indexOf(href) === 0);
          if (active) a.setAttribute('aria-current', 'page');
          else a.removeAttribute('aria-current');
        });
        var menu = document.querySelector('[data-mobile-menu]');
        var burger = document.querySelector('[data-burger]');
        if (menu) menu.hidden = true;
        if (burger) burger.setAttribute('aria-expanded', 'false');
      });
    </script>

    <style>
      /* su mobile lascia spazio in fondo per la capsula flottante (app-like) */
      @media (max-width: 900px) {
        body { padding-bottom: calc(92px + env(safe-area-inset-bottom, 0px)); }
      }
      .skip-link {
        position: absolute;
        left: var(--sp-4);
        top: -100px;
        z-index: var(--z-overlay);
        background: var(--c-brand);
        color: #fff;
        padding: var(--sp-2) var(--sp-4);
        border-radius: var(--radius-sm);
        transition: top var(--dur-fast) var(--ease);
      }
      .skip-link:focus { top: var(--sp-4); }
    </style>
  </body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site';

const waHref = site.whatsapp
  ? `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`
  : null;
---

<BaseLayout
  path="/grazie"
  title="Richiesta inviata"
  description="Grazie per averci scritto: ti ricontatteremo al più presto."
  noindex={true}
>
  <section class="ty">
    <div class="container ty__inner">
      <div class="ty__check" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5" />
        </svg>
      </div>
      <h1 data-enter>Richiesta inviata, grazie!</h1>
      <p class="ty__lead" data-enter="2">
        Abbiamo ricevuto il tuo messaggio: ti rispondiamo <strong>entro un giorno lavorativo</strong>.
        Nel frattempo puoi esplorare i nostri lavori o scriverci direttamente.
      </p>

      <div class="ty__actions" data-enter="3">
        <Button href="/" variant="primary">Torna alla home</Button>
        <Button href="/lavori" variant="secondary">Vedi i lavori</Button>
        {waHref && (
          <a class="ty__wa" href={waHref} target="_blank" rel="noopener">Scrivici su WhatsApp</a>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .ty {
    min-height: 62vh;
    display: grid;
    place-items: center;
    padding-top: clamp(7rem, 5rem + 7vw, 10rem);
    text-align: center;
  }
  .ty__inner { display: grid; justify-items: center; gap: var(--sp-4); max-width: 52ch; }
  .ty__check {
    display: grid;
    place-items: center;
    width: 68px; height: 68px;
    border-radius: 50%;
    color: var(--c-blue);
    background: var(--c-blue-soft);
    border: 1px solid var(--c-blue);
  }
  .ty__check svg { width: 34px; height: 34px; }
  .ty h1 { font-size: var(--fs-xl); }
  .ty__lead { font-size: var(--fs-md); color: var(--c-text-muted); }
  .ty__lead strong { color: var(--c-text); }
  .ty__actions { display: flex; gap: var(--sp-3); flex-wrap: wrap; justify-content: center; align-items: center; margin-top: var(--sp-3); }
  .ty__wa { color: var(--c-blue); font-weight: var(--fw-medium); font-size: var(--fs-sm); }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import PartnerHero from '../components/PartnerHero.astro';
import ServiceTabs from '../components/ServiceTabs.astro';
import Steps from '../components/Steps.astro';
import WorkCarousel from '../components/WorkCarousel.astro';
import SectorsMarquee from '../components/SectorsMarquee.astro';
import Testimonials from '../components/Testimonials.astro';
import Faq from '../components/Faq.astro';
import { faqs } from '../data/content';
import { faqPage } from '../lib/seo';
import { getCaseStudies } from '../lib/api';

// Contenuti dalla REST WP a build-time (fallback automatico ai mock se WP è offline).
const caseStudies = await getCaseStudies();
---

<BaseLayout path="/" schema={faqPage(faqs)}>
  <Hero />
  <Marquee />
  <PartnerHero />
  <ServiceTabs />
  <Steps />
  <WorkCarousel items={caseStudies} moreHref="/lavori" />
  <SectorsMarquee />
  <Testimonials />

  <Faq items={faqs} />
</BaseLayout>

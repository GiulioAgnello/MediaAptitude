---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import TeamMember from '../components/TeamMember.astro';
import Marquee from '../components/Marquee.astro';
import { values } from '../data/content';
import { getTeam } from '../lib/api';
import { site } from '../data/site';
import { breadcrumb } from '../lib/seo';

// Team dalla REST WP a build-time (fallback ai mock se WP è offline).
const team = await getTeam();

const schema = breadcrumb(
  [
    { name: 'Home', path: '/' },
    { name: 'Chi siamo', path: '/chi-siamo' },
  ],
  site.url
);
---

<BaseLayout
  path="/chi-siamo"
  title="Chi siamo: il team della web agency di Lecce"
  description="Il team di Media Aptitude: frontend, backend, design e SEO sotto lo stesso tetto, a Lecce. Le persone, i valori e le tecnologie dietro ogni progetto."
  schema={schema}
>
  <section class="intro">
    <div class="container intro__inner">
      <nav class="intro__crumbs" aria-label="Percorso">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Chi siamo</span>
      </nav>
      <h1 data-enter>Le persone dietro i progetti</h1>
      <p class="intro__lead" data-enter="2">
        Siamo uno studio digitale di Lecce: frontend, backend, design e SEO
        lavorano insieme dall'inizio. Un solo interlocutore, una sola
        responsabilità sul risultato — e la faccia ce la mettiamo noi.
      </p>
    </div>
  </section>

  <Section
    id="team"
    eyebrow="Il team"
    title="Profili complementari, un unico obiettivo"
    lead="Copriamo l'intero ciclo di vita del prodotto digitale, senza subappalti."
  >
    <div class="team stagger">
      {team.map((member) => (
        <div data-reveal><TeamMember member={member} /></div>
      ))}
    </div>
  </Section>

  <Section
    eyebrow="I valori"
    title="Principi non negoziabili"
    lead="Guidano ogni progetto, dal preventivo al post-lancio."
  >
    <div class="values stagger">
      {values.map((value) => (
        <article class="card card--glow value" data-reveal>
          <h3>{value.title}</h3>
          <p>{value.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section
    eyebrow="Tecnologie"
    title="Lo stack che usiamo"
    lead="Strumenti moderni e best practice consolidate: la scelta segue sempre l'obiettivo."
  />
  <Marquee />
</BaseLayout>

<style>
  .intro {
    padding-top: clamp(7rem, 5rem + 7vw, 10rem);
    background:
      radial-gradient(45% 40% at 50% 12%, rgba(77, 141, 255, 0.13) 0%, transparent 70%),
      radial-gradient(28% 22% at 34% 6%, rgba(255, 172, 10, 0.07) 0%, transparent 70%);
  }
  .intro__inner { display: grid; gap: var(--sp-5); max-width: 880px; }
  .intro__crumbs { display: flex; gap: var(--sp-2); font-size: var(--fs-xs); }
  .intro__crumbs a { transition: color var(--dur-fast) var(--ease); }
  .intro__crumbs a:hover { color: var(--c-text); }
  .intro__crumbs [aria-current] { color: var(--c-text-secondary); }
  .intro__lead { font-size: var(--fs-md); max-width: 60ch; }

  .team {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
  }
  .team > div { display: flex; }
  .team > div > :global(*) { width: 100%; }

  .values {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-5);
  }
  .value {
    display: grid;
    gap: var(--sp-3);
    padding: var(--sp-6);
    align-content: start;
  }
  .value p { font-size: var(--fs-sm); color: var(--c-text-secondary); }

  @media (max-width: 1024px) { .team { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 720px) { .values { grid-template-columns: 1fr; } }
  @media (max-width: 600px) { .team { grid-template-columns: 1fr; } }
</style>

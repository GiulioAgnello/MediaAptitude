---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
import { getPosts } from '../../lib/api';
import { site, cta } from '../../data/site';
import { breadcrumb } from '../../lib/seo';

const posts = await getPosts();

const schema = breadcrumb(
  [
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog' },
  ],
  site.url
);

const dateFmt = new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  path="/blog"
  title="Blog: digitale, SEO e web marketing per le imprese"
  description="Guide e consigli pratici su siti web, SEO, advertising e digitale per le imprese di Lecce e del Salento, dal team di Media Aptitude."
  schema={schema}
>
  <section class="intro">
    <div class="container intro__inner">
      <nav class="intro__crumbs" aria-label="Percorso">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Blog</span>
      </nav>
      <h1 data-enter>Idee e guide sul digitale</h1>
      <p class="intro__lead" data-enter="2">
        Consigli pratici su siti web, SEO e advertising, scritti per chi fa
        impresa — non per gli addetti ai lavori.
      </p>
    </div>
  </section>

  <Section>
    {posts.length > 0 ? (
      <div class="posts stagger">
        {posts.map((post) => (
          <a class="card post" href={`/blog/${post.slug}`} data-reveal>
            <figure class="post__media">
              {post.image ? (
                <img
                  src={post.image.url}
                  width={post.image.width}
                  height={post.image.height}
                  alt={post.image.alt ?? ''}
                  loading="lazy"
                />
              ) : (
                <div class="post__placeholder" aria-hidden="true"></div>
              )}
            </figure>
            <div class="post__body">
              <time class="post__date" datetime={post.published}>
                {dateFmt.format(new Date(post.published))}
              </time>
              <h2>{post.title}</h2>
              {post.excerpt && <p>{post.excerpt}</p>}
              <span class="post__more">Leggi l'articolo <span aria-hidden="true">→</span></span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty card card--glow" data-reveal>
        <h2>I primi articoli sono in arrivo</h2>
        <p>
          Stiamo preparando guide pratiche su SEO, siti web e digitale per le
          imprese. Nel frattempo, parlaci del tuo progetto.
        </p>
        <Button href={cta.href} variant="primary">{cta.label}</Button>
      </div>
    )}
  </Section>
</BaseLayout>

<style>
  .intro {
    padding-top: clamp(7rem, 5rem + 7vw, 10rem);
    background:
      radial-gradient(45% 40% at 50% 12%, rgba(77, 141, 255, 0.13) 0%, transparent 70%),
      radial-gradient(28% 22% at 34% 6%, rgba(255, 172, 10, 0.07) 0%, transparent 70%);
  }
  .intro__inner { display: grid; gap: var(--sp-5); max-width: 880px; }
  .intro__crumbs { display: flex; gap: var(--sp-2); font-size: var(--fs-xs); }
  .intro__crumbs a { transition: color var(--dur-fast) var(--ease); }
  .intro__crumbs a:hover { color: var(--c-text); }
  .intro__crumbs [aria-current] { color: var(--c-text-secondary); }
  .intro__lead { font-size: var(--fs-md); max-width: 60ch; }

  .posts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
  }
  .post {
    display: grid;
    transition: transform var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .post:hover { transform: translateY(-4px); border-color: var(--c-line-strong); }

  .post__media { aspect-ratio: 16 / 9; overflow: hidden; }
  .post__media img { width: 100%; height: 100%; object-fit: cover; }
  .post__placeholder {
    height: 100%;
    background:
      radial-gradient(60% 80% at 20% 100%, rgba(255, 172, 10, 0.2) 0%, transparent 70%),
      radial-gradient(70% 90% at 85% 0%, rgba(77, 141, 255, 0.24) 0%, transparent 70%),
      var(--c-surface-2);
  }

  .post__body { display: grid; gap: var(--sp-2); padding: var(--sp-5); align-content: start; }
  .post__body h2 { font-size: var(--fs-lg); }
  .post__body p { font-size: var(--fs-sm); color: var(--c-text-secondary); }
  .post__date { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.1em; }
  .post__more { font-size: var(--fs-sm); font-weight: var(--fw-medium); color: var(--c-blue); }

  .empty {
    display: grid;
    justify-items: center;
    gap: var(--sp-4);
    padding: var(--sp-8) var(--sp-6);
    text-align: center;
  }
  .empty p { max-width: 48ch; color: var(--c-text-secondary); }

  @media (max-width: 980px) { .posts { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .posts { grid-template-columns: 1fr; } }
</style>

---
/**
 * Hero home: badge, h1 con entrata blur-in, lead, CTA e foto grande
 * incorniciata con glow gradiente (stile riferimento).
 * La foto è un placeholder: sostituire src/assets/home-team.jpg con lo scatto reale.
 */
import { Picture } from 'astro:assets';
import Button from './Button.astro';
import { cta } from '../data/site';
import heroImg from '../assets/home-team.jpg';
---

<section class="hero">
  <div class="container hero__inner">
    <p class="hero__badge" data-enter>Agenzia digitale a Lecce e nel Salento</p>

    <h1 data-enter="2">
      Il digitale che porta clienti alle imprese del Salento
    </h1>

    <p class="hero__lead" data-enter="3">
      Siti web, e-commerce, SEO e software su misura per aziende e professionisti
      di Lecce e provincia. Progetti veloci, curati e costruiti per farti trovare.
    </p>

    <div class="hero__actions" data-enter="4">
      <Button href={cta.href} variant="primary">{cta.label}</Button>
      <Button href="/#servizi" variant="secondary">Scopri i servizi</Button>
    </div>

    <figure class="hero__media" data-enter="4">
      {/* astro:assets: genera AVIF/WebP responsive + width/height (no CLS).
          È l'immagine LCP → eager + fetchpriority alta. */}
      <Picture
        src={heroImg}
        formats={['avif', 'webp']}
        widths={[640, 960, 1280, 1600]}
        sizes="(max-width: 1140px) 100vw, 1080px"
        alt="Il team di Media Aptitude al lavoro nello studio di Lecce"
        loading="eager"
        fetchpriority="high"
      />
    </figure>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(8rem, 6rem + 8vw, 12rem);
    text-align: center;
    /* alone soffuso dietro al titolo, come il cielo del riferimento */
    background:
      radial-gradient(50% 38% at 50% 18%, rgba(77, 141, 255, 0.14) 0%, transparent 70%),
      radial-gradient(30% 24% at 38% 10%, rgba(255, 172, 10, 0.07) 0%, transparent 70%);
  }
  .hero__inner {
    display: grid;
    justify-items: center;
    gap: var(--sp-5);
  }

  .hero__badge {
    padding: 0.4rem 1rem;
    font-size: var(--fs-xs);
    color: var(--c-text-secondary);
    background: var(--c-surface);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-full);
    backdrop-filter: blur(8px);
  }

  h1 { max-width: 17ch; }

  .hero__lead {
    max-width: 52ch;
    font-size: var(--fs-md);
  }

  .hero__actions {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* Cornice foto: bordo translucido, radius grande, glow ambra/blu ai lati */
  .hero__media {
    margin-top: var(--sp-7);
    width: min(100%, 1080px);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow:
      var(--shadow-lg),
      -40px -10px 120px -60px rgba(255, 172, 10, 0.5),
      40px -10px 120px -60px rgba(77, 141, 255, 0.55);
  }
  .hero__media img { width: 100%; }
</style>

---
/**
 * Sezione servizi in home (stile "All-in-one" del riferimento):
 * indice sticky a sinistra, card grandi impilate a destra.
 * Ogni card = un gruppo di servizi con chips e link alla pagina dedicata.
 */
import Section from './Section.astro';
import Icon from './Icon.astro';
import { serviceGroups, services } from '../data/content';

const bySlug = new Map(services.map((s) => [s.slug, s]));
const groups = serviceGroups.map((g) => ({
  ...g,
  items: g.serviceSlugs.map((slug) => bySlug.get(slug)!).filter(Boolean),
}));
---

<Section
  id="servizi"
  eyebrow="Cosa facciamo"
  title="Tutto il digitale che serve alla tua impresa"
  lead="Un unico partner: presenza online, visibilità su Google e strumenti su misura."
>
  <div class="services">
    <nav class="services__index" aria-label="Indice servizi">
      <ul role="list">
        {groups.map((g, i) => (
          <li>
            <a href={`#gruppo-${g.slug}`} class="services__tab" data-tab={g.slug} aria-current={i === 0 ? 'true' : undefined}>
              <Icon name={g.icon} />
              {g.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="services__cards">
      {groups.map((g, i) => (
        <article id={`gruppo-${g.slug}`} class="card services__card" data-group={g.slug} style={`--i:${i}`}>
          <div class="services__body">
            <h3>{g.title}</h3>
            <p>{g.description}</p>
            <ul class="services__chips" role="list">
              {g.items.map((s) => (
                <li class="pill"><Icon name={s.icon} />{s.title}</li>
              ))}
            </ul>
            <a class="services__more" href={`/servizi/${g.slug}`}>
              <span>Scopri di più</span>
              <span class="services__arrow" aria-hidden="true">→</span>
            </a>
          </div>
          <div class="services__glow" aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>
</Section>

<style>
  .services {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2.4fr);
    gap: var(--sp-7);
    align-items: start;
  }

  .services__index {
    position: sticky;
    top: 110px;
  }
  .services__index ul { display: grid; }
  .services__tab {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-3);
    font-weight: var(--fw-medium);
    color: var(--c-text-muted);
    border-bottom: 1px solid var(--c-line);
    transition: color var(--dur-fast) var(--ease);
  }
  .services__tab :global(svg) { width: 20px; height: 20px; }
  .services__tab:hover { color: var(--c-text); }
  .services__tab[aria-current='true'] { color: var(--c-text); border-bottom-color: var(--c-blue); }

  .services__cards { display: grid; gap: var(--sp-6); }
  /* Sticky-stacking: ogni card si "incolla" con un offset crescente, così
     scorrendo si impilano una sopra l'altra (effetto sovrapposto/scorrimento). */
  .services__card {
    position: sticky;
    top: calc(96px + var(--i) * 2.4rem);
    padding: var(--sp-7);
    scroll-margin-top: 120px;
    /* fondo OPACO: la card che sale copre quella sotto senza trasparenze */
    background: linear-gradient(var(--c-surface-2), var(--c-surface-2)), var(--c-bg);
    transform-origin: center top;
    will-change: transform;
  }
  /* la card che scorre "sotto" si rimpicciolisce e si attenua */
  @supports (animation-timeline: view()) {
    .services__card {
      animation: cardStack linear both;
      animation-timeline: view();
      animation-range: exit 0% exit 100%;
    }
    @keyframes cardStack {
      to { transform: scale(0.93); opacity: 0.55; }
    }
  }
  .services__body {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--sp-4);
    max-width: 56ch;
  }
  .services__body p { color: var(--c-text-secondary); }
  .services__chips { display: flex; flex-wrap: wrap; gap: var(--sp-2); }

  /* Link "Scopri di più" come pill evidente con freccia animata */
  .services__more {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 0.6rem 1.15rem;
    font-weight: var(--fw-medium);
    color: var(--c-text);
    background: var(--c-surface);
    border: 1px solid var(--c-line-strong);
    border-radius: var(--radius-full);
    transition:
      color var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease),
      background var(--dur-fast) var(--ease);
  }
  .services__arrow {
    display: inline-block;
    transition: transform var(--dur) var(--ease);
  }
  .services__more:hover,
  .services__more:focus-visible {
    color: var(--c-blue);
    border-color: var(--c-blue);
    background: var(--c-blue-soft);
  }
  .services__more:hover .services__arrow,
  .services__more:focus-visible .services__arrow { transform: translateX(4px); }

  /* Alone gradiente nell'angolo della card */
  .services__glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(45% 60% at 92% 10%, rgba(255, 172, 10, 0.16) 0%, transparent 70%),
      radial-gradient(55% 70% at 100% 60%, rgba(77, 141, 255, 0.18) 0%, transparent 70%);
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .services { grid-template-columns: 1fr; }
    .services__index { display: none; }
    /* niente sticky-stacking su mobile: lista normale */
    .services__card { position: static; padding: var(--sp-5); }
  }

  /* Mobile: card sfogliabili in orizzontale (swipe, stile social) → non allungano la pagina */
  @media (max-width: 760px) {
    .services__cards {
      display: flex;
      gap: var(--sp-4);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }
    .services__cards::-webkit-scrollbar { display: none; }
    .services__card {
      flex: 0 0 86%;   /* ~14% per intravedere la card successiva (peek) */
      min-width: 0;
      scroll-snap-align: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .services__card { position: relative; top: auto; animation: none; }
    .services__arrow { transition: none; }
  }
</style>

<script>
  // Evidenzia nell'indice il gruppo attualmente visibile. Re-init ad ogni pagina.
  function initServiceTabs() {
    const tabs = new Map(
      [...document.querySelectorAll<HTMLAnchorElement>('[data-tab]')].map((el) => [el.dataset.tab!, el])
    );
    if (!tabs.size) return;
    const groups = [...document.querySelectorAll<HTMLElement>('[data-group]')];
    if (groups[0]?.dataset.tabsInit) return;
    if (groups[0]) groups[0].dataset.tabsInit = '1';
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const slug = (e.target as HTMLElement).dataset.group!;
          tabs.forEach((tab, key) =>
            key === slug ? tab.setAttribute('aria-current', 'true') : tab.removeAttribute('aria-current')
          );
        }
      },
      { rootMargin: '-40% 0px -50% 0px' }
    );
    groups.forEach((el) => io.observe(el));
  }
  document.addEventListener('astro:page-load', initServiceTabs);
</script>

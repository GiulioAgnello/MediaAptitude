---
/**
 * Testimonianze clienti — recensioni reali importate da Google (build-time).
 * Con `items` vuoto la sezione NON viene renderizzata: compare da sola quando
 * ci saranno recensioni sul profilo Google (predisposto in N2).
 */
import Section from './Section.astro';
import type { Testimonial } from '../data/content';

interface Props { items?: Testimonial[]; }
const { items = [] } = Astro.props;
const hasReviews = items.length > 0;
---

{hasReviews && (
  <Section
    id="testimonianze"
    eyebrow="Dicono di noi"
    title="La fiducia dei clienti"
    align="center"
  >
    <div class="quotes stagger">
      {items.map((t) => (
        <figure class="card quotes__item" data-reveal>
          {t.rating && (
            <div class="quotes__stars" aria-label={`Valutazione ${t.rating} su 5`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <span class:list={['quotes__star', { 'is-on': i < Math.round(t.rating!) }]} aria-hidden="true">★</span>
              ))}
            </div>
          )}
          <blockquote>
            <p>“{t.quote}”</p>
          </blockquote>
          <figcaption>
            {t.photo && (
              <img src={t.photo.url} width="44" height="44" alt="" loading="lazy" referrerpolicy="no-referrer" />
            )}
            <span>
              <strong>{t.author}</strong>
              <small>{t.role}</small>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="quotes__source">
      Recensioni verificate su Google
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M12 11v2h5.5c-.2 1.3-1.6 3.9-5.5 3.9A5.9 5.9 0 0 1 6.1 12 5.9 5.9 0 0 1 12 6.1c1.7 0 2.8.7 3.5 1.3l1.9-1.8C16.1 4.4 14.3 3.6 12 3.6a8.4 8.4 0 1 0 0 16.8c4.8 0 8-3.4 8-8.1 0-.6 0-1-.1-1.3H12Z"/></svg>
    </p>
  </Section>
)}

<style>
  .quotes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--sp-5);
  }
  .quotes__item {
    display: grid;
    gap: var(--sp-4);
    align-content: start;
    padding: var(--sp-6);
  }
  .quotes__stars { display: flex; gap: 2px; font-size: var(--fs-md); }
  .quotes__star { color: var(--c-line-strong); }
  .quotes__star.is-on { color: var(--c-amber); }
  .quotes__item blockquote p {
    color: var(--c-text-secondary);
    line-height: var(--lh-normal);
  }
  .quotes__item figcaption {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: var(--sp-2);
  }
  .quotes__item img { border-radius: 50%; object-fit: cover; }
  .quotes__item figcaption span { display: grid; }
  .quotes__item small { font-size: var(--fs-xs); color: var(--c-text-muted); }

  .quotes__source {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    justify-self: center;
    margin-top: var(--sp-6);
    font-size: var(--fs-xs);
    color: var(--c-text-muted);
  }
</style>

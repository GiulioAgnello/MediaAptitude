---
/**
 * Componente SEO centralizzato.
 * Genera title, meta description, canonical, Open Graph, Twitter card
 * e i dati strutturati schema.org (JSON-LD) per i rich results.
 */
import { site } from '../data/site';
import type { WpSeo } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  /** Path della pagina, es. "/servizi". Usato per il canonical. */
  path?: string;
  image?: string;
  /** Se true aggiunge noindex (utile per pagine tecniche/grazie). */
  noindex?: boolean;
  /**
   * Schemi JSON-LD specifici della pagina (es. BreadcrumbList).
   * Vengono aggiunti a Organization + WebSite già presenti site-wide.
   */
  schema?: Record<string, unknown> | Record<string, unknown>[];
  /** Meta SEO da WordPress (Yoast): se presenti, vincono sui default. */
  wpSeo?: WpSeo | null;
}

const {
  title,
  description = site.description,
  path = '/',
  image = site.ogImage,
  noindex = false,
  schema,
  wpSeo = null,
} = Astro.props;

// I valori di WP (se presenti) hanno la precedenza sui default statici.
const fullTitle =
  wpSeo?.title ??
  (title ? `${title} — ${site.name}` : `${site.name} — ${site.tagline}`);
const metaDescription = wpSeo?.description ?? description;
const isNoindex = wpSeo?.noindex ?? noindex;
const canonical = new URL(path, site.url).href;
const ogImageUrl = new URL(wpSeo?.ogImage ?? image, site.url).href;

// --- Dati strutturati site-wide ----------------------------------------
// @id stabili: permettono ad altri schemi di "puntare" a questi nodi
// (es. una pagina che dichiara publisher = la nostra Organization).
const orgId = `${site.url}/#organization`;
const siteId = `${site.url}/#website`;

const localId = `${site.url}/#localbusiness`;

const organizationSchema = {
  '@type': 'Organization',
  '@id': orgId,
  name: site.legalName,
  url: site.url,
  email: site.email,
  telephone: site.phone || undefined,
  description: site.description,
  logo: {
    '@type': 'ImageObject',
    url: new URL('/logo.png', site.url).href,
  },
  // sameAs: profili ufficiali (social). Compilare site.social in data/site.ts.
  ...(site.social.length ? { sameAs: site.social } : {}),
};

// LocalBusiness/ProfessionalService: leva SEO locale (Lecce e Salento).
// areaServed dichiara a Google le aree geografiche servite.
const localBusinessSchema = {
  '@type': 'ProfessionalService',
  '@id': localId,
  name: site.name,
  url: site.url,
  email: site.email,
  telephone: site.phone || undefined,
  priceRange: site.priceRange,
  description: site.description,
  image: new URL(site.ogImage, site.url).href,
  parentOrganization: { '@id': orgId },
  areaServed: site.areaServed.map((name) => ({ '@type': 'AdministrativeArea', name })),
  address: {
    '@type': 'PostalAddress',
    ...(site.streetAddress ? { streetAddress: site.streetAddress } : {}),
    addressLocality: 'Lecce',
    ...(site.postalCode ? { postalCode: site.postalCode } : {}),
    addressRegion: 'Puglia',
    addressCountry: 'IT',
  },
  // geo incluso solo se lat/lng reali sono stati inseriti in data/site.ts
  ...(site.geo.lat && site.geo.lng
    ? { geo: { '@type': 'GeoCoordinates', latitude: site.geo.lat, longitude: site.geo.lng } }
    : {}),
  ...(site.social.length ? { sameAs: site.social } : {}),
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': siteId,
  url: site.url,
  name: site.name,
  inLanguage: site.locale,
  publisher: { '@id': orgId },
};

// @graph: array di nodi collegati tra loro tramite @id. È il modo
// raccomandato da Google per dichiarare più entità in un solo blocco.
const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [organizationSchema, localBusinessSchema, websiteSchema, ...pageSchemas],
};
---

<title>{fullTitle}</title>
<meta name="description" content={metaDescription} />
<link rel="canonical" href={canonical} />
<meta name="theme-color" content="#000000" />
{isNoindex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content={site.locale} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:secure_url" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={fullTitle} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Dati strutturati (schema.org / JSON-LD).
     set:html evita che Astro faccia escape delle virgolette del JSON. -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

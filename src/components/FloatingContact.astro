---
/**
 * FloatingContact — pulsanti flottanti WhatsApp + Chiama (in basso a destra).
 * Si mostrano solo se configurati in site.ts (whatsapp / phone). Su mobile sono
 * sollevati sopra la bottom bar. Posizionati con inset/margin: niente scroll
 * orizzontale.
 */
import { site } from '../data/site';

const waHref = site.whatsapp
  ? `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`
  : null;
const telHref = site.phone ? `tel:${site.phone.replace(/\s+/g, '')}` : null;
---

{(waHref || telHref) && (
  <div class="fab" aria-label="Contatto rapido">
    {telHref && (
      <a class="fab__btn fab__btn--call" href={telHref} aria-label="Chiamaci">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.2-1.1a2 2 0 0 1 2.1-.5c.8.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2Z"/>
        </svg>
      </a>
    )}
    {waHref && (
      <a class="fab__btn fab__btn--wa" href={waHref} target="_blank" rel="noopener" aria-label="Scrivici su WhatsApp">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.4A10 10 0 1 0 12 2Zm5.7 14.1c-.2.7-1.4 1.3-2 1.4-.5.1-1.2.1-1.9-.1-.4-.1-1-.3-1.8-.6-3-1.3-5-4.4-5.1-4.6-.2-.2-1.3-1.7-1.3-3.2 0-1.5.8-2.3 1-2.6.3-.3.6-.4.8-.4h.6c.2 0 .5 0 .7.5l.9 2.1c.1.2.1.4 0 .6l-.4.6-.3.3c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l.9-1c.2-.3.5-.2.7-.1l2 1c.3.1.5.2.5.3.1.2.1.8-.1 1.4Z"/>
        </svg>
      </a>
    )}
  </div>
)}

<style>
  .fab {
    position: fixed;
    right: var(--sp-4);
    bottom: var(--sp-5);
    z-index: var(--z-header);
    display: grid;
    gap: var(--sp-3);
  }
  .fab__btn {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-full);
    color: #fff;
    box-shadow: var(--shadow-lg);
    transition: transform var(--dur-fast) var(--ease), filter var(--dur-fast) var(--ease);
  }
  .fab__btn:hover { transform: translateY(-2px); filter: brightness(1.06); }
  .fab__btn svg { width: 26px; height: 26px; }
  .fab__btn--wa { background: #25d366; }
  .fab__btn--call {
    background: var(--c-surface-2);
    color: var(--c-text);
    border: 1px solid var(--c-line-strong);
    backdrop-filter: blur(10px);
  }

  /* su mobile: sopra la bottom bar */
  @media (max-width: 900px) {
    .fab { bottom: calc(env(safe-area-inset-bottom, 0px) + 5.5rem); right: var(--sp-3); }
    .fab__btn { width: 48px; height: 48px; }
    .fab__btn svg { width: 24px; height: 24px; }
  }
</style>

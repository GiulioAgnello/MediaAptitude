---
/**
 * TrustBar — fascia di numeri di sintesi (autorevolezza a colpo d'occhio).
 * Dati dal CPT WP `ma_stat`; se WP non ne ha, usa i placeholder onesti di
 * content.ts. Non viene renderizzata solo se la lista è davvero vuota.
 */
import type { Stat } from '../data/content';

interface Props { items?: Stat[]; }
const { items = [] } = Astro.props;
---

{items.length > 0 && (
  <section class="trust" aria-label="I nostri numeri" data-trust>
    <div class="container">
      <dl class="trust__grid stagger">
        {items.map((s) => (
          <div class="trust__item" data-reveal>
            <dt class="trust__value">
              <span class="trust__num" data-value={s.value}>{s.value}</span><span class="trust__suffix">{s.suffix}</span>
            </dt>
            <dd class="trust__label">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
)}

<script>
  // Count-up: quando la fascia entra in viewport, i numeri scorrono da 0 al
  // valore finale. I valori non numerici (testo) restano invariati.
  function initTrust() {
    const section = document.querySelector<HTMLElement>('[data-trust]');
    if (!section || section.dataset.trustInit) return;
    section.dataset.trustInit = '1';
    const nums = [...section.querySelectorAll<HTMLElement>('.trust__num')];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const parse = (s: string) => {
      const m = String(s).replace(',', '.').match(/^-?\d+(\.\d+)?$/);
      return m ? { val: parseFloat(m[0]), dec: m[1] ? m[1].length - 1 : 0 } : null;
    };
    const targets = nums.map((el) => parse(el.dataset.value || ''));

    if (!reduce) {
      // reset a 0 i valori animabili (gli altri restano come da build)
      nums.forEach((el, i) => { if (targets[i]) el.textContent = (0).toFixed(targets[i]!.dec); });

      let done = false;
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (!e.isIntersecting || done) continue;
          done = true;
          const t0 = performance.now();
          const dur = 1400;
          const step = (now: number) => {
            const p = Math.min(1, (now - t0) / dur);
            const k = ease(p);
            nums.forEach((el, i) => {
              const tg = targets[i];
              if (tg) el.textContent = (tg.val * k).toFixed(tg.dec);
            });
            if (p < 1) requestAnimationFrame(step);
            else nums.forEach((el, i) => { if (targets[i]) el.textContent = el.dataset.value || ''; });
          };
          requestAnimationFrame(step);
        }
      }, { threshold: 0.4 });
      io.observe(section);
    }
  }
  document.addEventListener('astro:page-load', initTrust);
</script>

<style>
  .trust { padding-block: var(--sp-8); }
  .trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
    padding: var(--sp-6);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-lg);
    background: var(--c-surface);
  }
  .trust__item { display: grid; gap: var(--sp-1); text-align: center; }
  .trust__value {
    font-family: var(--font-heading);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-heading);
    line-height: 1;
    background: var(--grad-signature);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .trust__suffix { -webkit-text-fill-color: currentColor; }
  .trust__label { font-size: var(--fs-sm); color: var(--c-text-muted); }

  @media (max-width: 720px) {
    .trust__grid { grid-template-columns: repeat(2, 1fr); gap: var(--sp-6) var(--sp-4); }
  }
</style>

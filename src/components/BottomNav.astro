---
/**
 * BottomNav — barra di navigazione fissa in basso, stile app.
 * Visibile solo su mobile (≤900px, come il menu burger). 4 voci principali
 * con icona + label. Active state in base al path corrente. Safe-area inset
 * per i telefoni con gesture bar/notch. L'header in alto resta per il menu completo.
 */
import { cta } from '../data/site';

const path = Astro.url.pathname;
const isHome = path === '/';

const items = [
  { label: 'Home', href: '/', icon: 'home', active: isHome },
  { label: 'Servizi', href: '/#servizi', icon: 'grid', active: false },
  { label: 'Lavori', href: '/lavori', icon: 'work', active: path.startsWith('/lavori') },
  { label: 'Contatti', href: cta.href, icon: 'mail', active: path.startsWith('/contatti') },
];
---

<nav class="bottomnav" aria-label="Navigazione rapida">
  <ul role="list">
    {items.map((item) => (
      <li>
        <a href={item.href} class="bottomnav__link" aria-current={item.active ? 'page' : undefined}>
          <span class="bottomnav__icon" aria-hidden="true">
            {item.icon === 'home' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 10.5 12 3l9 7.5" /><path d="M5 9.5V21h14V9.5" />
              </svg>
            )}
            {item.icon === 'grid' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7" rx="1.5" /><rect x="14" y="3" width="7" height="7" rx="1.5" />
                <rect x="3" y="14" width="7" height="7" rx="1.5" /><rect x="14" y="14" width="7" height="7" rx="1.5" />
              </svg>
            )}
            {item.icon === 'work' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="7" width="18" height="13" rx="2" /><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
              </svg>
            )}
            {item.icon === 'mail' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="5" width="18" height="14" rx="2" /><path d="m4 7 8 6 8-6" />
              </svg>
            )}
          </span>
          <span class="bottomnav__label">{item.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  /* Capsula flottante stile "Dynamic Island": staccata dai bordi, vetro traslucido */
  .bottomnav {
    position: fixed;
    inset-inline: 0;                 /* left:0 + right:0: la capsula resta nel viewport */
    bottom: calc(env(safe-area-inset-bottom, 0px) + 0.85rem);
    width: min(100% - 1.6rem, 400px);
    margin-inline: auto;             /* centrata senza left:50%/translate (niente overflow) */
    z-index: var(--z-header);
    display: none;   /* visibile solo su mobile */
    padding: 0.4rem;
    background: color-mix(in srgb, var(--c-bg) 58%, transparent);
    border: 1px solid var(--c-line-strong);
    border-radius: var(--radius-full);
    backdrop-filter: blur(22px) saturate(1.25);
    -webkit-backdrop-filter: blur(22px) saturate(1.25);
    box-shadow:
      var(--shadow-lg),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .bottomnav ul {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.2rem;
  }
  .bottomnav__link {
    display: grid;
    justify-items: center;
    gap: 3px;
    padding: 0.5rem 0.25rem;
    border-radius: var(--radius-md);
    color: var(--c-text-muted);
    transition: color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
  }
  .bottomnav__icon { display: grid; place-items: center; }
  .bottomnav__icon svg { width: 22px; height: 22px; }
  .bottomnav__label {
    font-size: 0.7rem;
    font-weight: var(--fw-medium);
    letter-spacing: 0.01em;
  }
  .bottomnav__link:hover { color: var(--c-text-secondary); }
  .bottomnav__link[aria-current='page'] {
    color: var(--c-blue);
    background: var(--c-blue-soft);   /* pill attiva */
  }

  @media (max-width: 900px) {
    .bottomnav { display: block; }
  }
</style>

---
/** Set di icone inline (SVG) per i servizi. Niente librerie esterne. */
interface Props { name: 'web' | 'app' | 'ecommerce' | 'seo' | 'ads' | 'crm' | 'training'; }
const { name } = Astro.props;
---

<span class="icon" aria-hidden="true">
  {name === 'web' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="9" /><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" />
    </svg>
  )}
  {name === 'app' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2.5" y="4" width="19" height="13" rx="2" /><path d="M8 21h8M12 17v4M7 8l-2 2.5L7 13M17 8l2 2.5L17 13" />
    </svg>
  )}
  {name === 'ecommerce' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 4h2l2.4 12.4a1 1 0 0 0 1 .8h8.7a1 1 0 0 0 1-.8L21 8H6" /><circle cx="9" cy="20" r="1" /><circle cx="18" cy="20" r="1" />
    </svg>
  )}
  {name === 'seo' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3M8.5 11.5l2 2 3.5-4" />
    </svg>
  )}
  {name === 'ads' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 10v4a1 1 0 0 0 1 1h3l5 4V5L7 9H4a1 1 0 0 0-1 1Z" /><path d="M16 9a4 4 0 0 1 0 6" />
    </svg>
  )}
  {name === 'crm' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="9" cy="8" r="3.2" /><path d="M3.5 20a5.5 5.5 0 0 1 11 0M16 11l2 2 4-4" />
    </svg>
  )}
  {name === 'training' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3 2 8l10 5 10-5-10-5Z" /><path d="M6 10.5V15c0 1.5 2.7 3 6 3s6-1.5 6-3v-4.5M22 8v5" />
    </svg>
  )}
</span>

<style>
  .icon { display: inline-flex; }
  .icon svg { width: 26px; height: 26px; }
</style>

---
/**
 * FAQ accessibile con <details>/<summary> nativi (zero JS).
 * Lo schema FAQPage per la SEO è costruito in lib/seo.ts e passato
 * al BaseLayout dalla pagina che usa questo componente.
 */
import Section from './Section.astro';
import type { Faq } from '../data/content';

interface Props { items: Faq[]; }
const { items } = Astro.props;
---

<Section
  id="faq"
  eyebrow="Domande frequenti"
  title="Le risposte che cerchi"
  lead="Costi, tempi e metodo: tutto quello che ci chiedono prima di iniziare."
>
  <div class="faq stagger">
    {items.map((item) => (
      <details class="card faq__item" data-reveal>
        <summary class="faq__q">
          {item.question}
          <span class="faq__toggle" aria-hidden="true"></span>
        </summary>
        <p class="faq__a">{item.answer}</p>
      </details>
    ))}
  </div>
</Section>

<style>
  .faq {
    display: grid;
    gap: var(--sp-3);
    max-width: 820px;
    margin-inline: auto;
  }
  .faq__item { border-radius: var(--radius-md); }
  .faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-4) var(--sp-5);
    font-weight: var(--fw-medium);
    color: var(--c-text);
    cursor: pointer;
    list-style: none;
  }
  .faq__q::-webkit-details-marker { display: none; }

  /* Indicatore +/− disegnato in CSS */
  .faq__toggle {
    position: relative;
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }
  .faq__toggle::before,
  .faq__toggle::after {
    content: '';
    position: absolute;
    inset: 50% auto auto 0;
    width: 100%;
    height: 2px;
    background: var(--c-text-muted);
    border-radius: 2px;
    transition: transform var(--dur) var(--ease);
  }
  .faq__toggle::after { transform: rotate(90deg); }
  details[open] .faq__toggle::after { transform: rotate(0deg); }

  .faq__a {
    padding: 0 var(--sp-5) var(--sp-5);
    font-size: var(--fs-sm);
    color: var(--c-text-secondary);
    max-width: 70ch;
  }
</style>

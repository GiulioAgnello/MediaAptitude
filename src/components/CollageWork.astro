---
/**
 * Portfolio "collage" in stile Keyformat.
 * - Default (no JS / reduced-motion / mobile): cluster di card leggibile (flex-wrap).
 * - Con GSAP (desktop): la sezione si "pinna" e lo scroll verticale traina il track
 *   in orizzontale (scrub) con parallax per profondità.
 * GSAP è caricato on-demand (dynamic import) solo quando la sezione si avvicina.
 *
 * Ogni lavoro è una COPPIA desktop (frame browser) + mobile (frame telefono),
 * mostrati insieme per comunicare il responsive. Le immagini arrivano dalla REST
 * (imageDesktop / imageMobile); se assenti si ricade su un mockup a gradiente.
 */
import type { CaseStudy } from '../data/content';
interface Props { items: CaseStudy[]; }
const { items } = Astro.props;

const gradients = [
  'linear-gradient(135deg, #3b82f6, #06b6d4, #818cf8)',
  'linear-gradient(135deg, #2563eb, #3b82f6)',
  'linear-gradient(135deg, #06b6d4, #3b82f6)',
  'linear-gradient(135deg, #818cf8, #9333ea)',
  'linear-gradient(135deg, #3b82f6, #818cf8)',
  'linear-gradient(135deg, #06b6d4, #0d9488)',
];

// Scatter "artistico" per coppia: profondità (parallax), offset Y, rotazione.
const layout = [
  { depth: 1.0, ty: -40, rot: -2 },
  { depth: 1.8, ty: 50,  rot: 2 },
  { depth: 1.3, ty: 10,  rot: -1 },
  { depth: 2.0, ty: -60, rot: 3 },
  { depth: 1.1, ty: 40,  rot: -3 },
  { depth: 1.5, ty: -10, rot: 2 },
];
const lay = (i: number) => layout[i % layout.length];
---

<section class="collage" id="lavori" data-collage aria-label="Lavori realizzati">
  <div class="collage__inner" data-collage-inner>
    <div class="collage__track" data-collage-track>

      <header class="collage__intro collage__cell">
        <span class="eyebrow">Portfolio</span>
        <h2>Lavori<br />realizzati</h2>
        <p class="lead">Progetti, tecnologie e risultati. Una storia che prende forma grazie alle persone.</p>
      </header>

      {items.map((item, i) => {
        const l = lay(i);
        const g = gradients[i % gradients.length];
        // Il cluster è cliccabile verso il lavoro online quando `url` è presente.
        const Tag = item.url ? 'a' : 'article';
        const linkProps = item.url
          ? {
              href: item.url,
              target: '_blank',
              rel: 'noopener',
              'aria-label': `${item.title} — apri il sito (nuova scheda)`,
            }
          : {};
        return (
          <Tag
            class:list={['work', 'collage__cell', { 'is-link': item.url }]}
            data-depth={l.depth}
            style={`--ty:${l.ty}px; --rot:${l.rot}deg`}
            {...linkProps}
          >
            <div class="work__devices">
              <div class="device device--browser is-lg">
                <div class="device__frame">
                  <span class="device__bar" aria-hidden="true"><i></i><i></i><i></i></span>
                  {item.imageDesktop ? (
                    <img
                      class="device__screen"
                      src={item.imageDesktop.url}
                      width={item.imageDesktop.width}
                      height={item.imageDesktop.height}
                      alt={item.imageDesktop.alt || `${item.title} — versione desktop`}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span class="device__screen device__screen--ph" style={`background:${g}`}></span>
                  )}
                </div>
              </div>
              <div class="device device--phone is-sm">
                <div class="device__frame">
                  {item.imageMobile ? (
                    <img
                      class="device__screen"
                      src={item.imageMobile.url}
                      width={item.imageMobile.width}
                      height={item.imageMobile.height}
                      alt={item.imageMobile.alt || `${item.title} — versione mobile`}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span class="device__screen device__screen--ph" style={`background:${g}`}></span>
                  )}
                </div>
              </div>
            </div>
            <div class="device__caption">
              <span class="device__cat">{item.category}</span>
              <span class="device__title">{item.title}</span>
              <span class="device__result">{item.result}</span>
              {item.url && <span class="device__link">Visita il sito <span aria-hidden="true">↗</span></span>}
            </div>
          </Tag>
        );
      })}

      <div class="collage__statement collage__cell" aria-hidden="true">
        <p>Ogni progetto è unico<br />come la storia che racconta.</p>
      </div>

    </div>
  </div>
</section>

<style>
  .collage {
    background: var(--c-ink-900);
    color: #fff;
    overflow: hidden;
  }
  .collage__inner {
    display: flex;
    align-items: center;
    padding-block: var(--section-py);
  }
  .collage__track {
    display: flex;
    flex-wrap: wrap;            /* fallback leggibile senza JS */
    align-items: center;
    justify-content: center;
    gap: clamp(2rem, 1rem + 4vw, 5rem);
    padding-inline: var(--container-pad);
    width: 100%;
  }

  /* Intro e statement */
  .collage__intro { max-width: 460px; }
  .collage__intro h2 { color: #fff; font-size: var(--fs-3xl); }
  .collage__intro .lead { color: var(--c-slate-400); margin-top: var(--sp-4); }
  .collage__statement p {
    font-family: var(--font-heading);
    font-weight: var(--fw-bold);
    font-size: clamp(1.8rem, 1rem + 3vw, 3.2rem);
    line-height: var(--lh-tight);
    color: #fff;
    max-width: 14ch;
  }

  /* Cluster lavoro: coppia di dispositivi + caption */
  .work { flex: none; display: grid; gap: var(--sp-4); }
  .work__devices { position: relative; display: inline-block; margin-bottom: 22px; }

  /* Card dispositivo */
  .device { display: grid; }
  .device__frame {
    border-radius: var(--radius-md);
    background: #fff;
    box-shadow: var(--shadow-lg);
    padding: 10px;
    overflow: hidden;
  }
  .device__bar { display: flex; gap: 6px; padding: 4px 4px 10px; }
  .device__bar i { width: 9px; height: 9px; border-radius: 50%; background: #d7dde6; }
  .device__screen { display: block; border-radius: 8px; width: 100%; object-fit: cover; }
  img.device__screen { height: auto; }

  .device--browser .device__screen { aspect-ratio: 16 / 10; }
  .device--phone .device__frame { border-radius: 28px; padding: 12px; }
  .device--phone .device__screen { aspect-ratio: 9 / 18; border-radius: 18px; }

  /* Il browser è la base; il telefono si sovrappone in basso a destra. */
  .work__devices .device--browser { width: clamp(280px, 34vw, 440px); }
  .work__devices .device--phone {
    position: absolute;
    right: clamp(-40px, -2vw, -20px);
    bottom: -22px;
    width: clamp(108px, 13vw, 150px);
    z-index: 2;
  }

  .device__caption { display: grid; gap: 2px; max-width: 30ch; margin-top: var(--sp-4); }
  .device__cat {
    font-family: var(--font-heading);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-accent);
  }
  .device__title { font-family: var(--font-heading); font-weight: var(--fw-bold); font-size: var(--fs-md); color: #fff; }
  .device__result { font-size: var(--fs-sm); color: var(--c-slate-400); }
  .device__link {
    margin-top: 4px;
    font-family: var(--font-heading);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-sm);
    color: var(--c-accent);
  }

  /* Cluster-link: eredita il colore, niente sottolineatura, micro-interazione. */
  a.work { color: inherit; text-decoration: none; cursor: pointer; }
  a.work.is-link { transition: transform var(--dur-fast) var(--ease); }
  a.work .device__frame { transition: box-shadow var(--dur-fast) var(--ease); }
  a.work.is-link:hover .device--browser .device__frame { box-shadow: 0 0 0 2px var(--c-accent), var(--shadow-lg); }
  a.work.is-link:hover .device__link { text-decoration: underline; }
  a.work.is-link:focus-visible { outline: 2px solid var(--c-accent); outline-offset: 6px; border-radius: var(--radius-md); }

  /* ---- Modalità pinned (attivata da GSAP) ---- */
  .collage.is-pinned .collage__inner { height: 100vh; }
  .collage.is-pinned .collage__track {
    flex-wrap: nowrap;
    justify-content: flex-start;
    will-change: transform;
  }
  .collage.is-pinned .work { transform: translateY(var(--ty)) rotate(var(--rot)); }

  @media (max-width: 860px) {
    .collage__track { gap: var(--sp-7); }
    .work__devices .device--browser { width: min(78vw, 360px); }
    .work__devices .device--phone { width: min(26vw, 124px); }
  }
</style>

<script>
  // Carica GSAP + ScrollTrigger SOLO quando la sezione si avvicina e solo dove ha senso.
  const section = document.querySelector<HTMLElement>('[data-collage]');
  const track = section?.querySelector<HTMLElement>('[data-collage-track]');
  const wideEnough = window.matchMedia('(min-width: 861px)');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

  function initCollage() {
    if (!section || !track || !wideEnough.matches || reduce.matches) return;

    Promise.all([import('gsap'), import('gsap/ScrollTrigger')])
      .then(([{ gsap }, { ScrollTrigger }]) => {
        gsap.registerPlugin(ScrollTrigger);
        section.classList.add('is-pinned');

        const distance = () => Math.max(0, track.scrollWidth - window.innerWidth + 120);

        // Track in orizzontale, traino dallo scroll verticale (scrub).
        const drive = gsap.to(track, {
          x: () => -distance(),
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top top',
            end: () => '+=' + distance(),
            pin: true,
            scrub: 1,
            anticipatePin: 1,
            invalidateOnRefresh: true,
          },
        });

        // Parallax: le card si muovono di più/meno in base alla profondità.
        try {
          section.querySelectorAll<HTMLElement>('[data-depth]').forEach((el) => {
            const depth = parseFloat(el.dataset.depth || '1');
            gsap.to(el, {
              x: (depth - 1.4) * 120,
              ease: 'none',
              scrollTrigger: {
                trigger: el,
                containerAnimation: drive,
                start: 'left right',
                end: 'right left',
                scrub: true,
              },
            });
          });
        } catch (e) { /* il parallax è un extra: se fallisce, resta lo scrub base */ }

        // Ricalcola dopo il caricamento dei font (cambiano le larghezze).
        if ((document as any).fonts?.ready) {
          (document as any).fonts.ready.then(() => ScrollTrigger.refresh());
        }
      })
      .catch(() => { /* GSAP non disponibile: resta il fallback statico */ });
  }

  // On-demand: attiva quando manca poco alla sezione.
  if (section && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        if (entries.some((e) => e.isIntersecting)) { obs.disconnect(); initCollage(); }
      },
      { rootMargin: '600px 0px' }
    );
    io.observe(section);
  } else {
    initCollage();
  }
</script>

---
import Logo from './Logo.astro';
import Button from './Button.astro';
import { mainNav, cta } from '../data/site';
---

<header class="header" data-header>
  <div class="header__inner">
    <Logo />

    {/* Nav centrale a pillola (stile Cosmoq). Dropdown CSS-only: hover + focus-within. */}
    <nav class="nav" aria-label="Navigazione principale">
      <ul class="nav__list" role="list">
        {mainNav.map((item) => (
          <li class:list={['nav__item', { 'has-sub': !!item.children }]}>
            <a class="nav__link" href={item.href}>{item.label}</a>
            {item.children && (
              <ul class="nav__sub" role="list">
                {item.children.map((child) => (
                  <li><a class="nav__sublink" href={child.href}>{child.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__cta">
      <button class="theme-toggle" data-theme-toggle type="button" aria-label="Cambia tema">
        <svg class="theme-toggle__sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
        </svg>
        <svg class="theme-toggle__moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
        </svg>
      </button>
      <Button href={cta.href} variant="primary">{cta.label}</Button>
    </div>

    <button class="burger" data-burger aria-label="Apri menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" data-mobile-menu hidden>
    <nav aria-label="Navigazione mobile">
      <ul role="list">
        {mainNav.map((item) => (
          <>
            <li><a href={item.href} data-mobile-link>{item.label}</a></li>
            {item.children?.map((child) => (
              <li><a class="mobile-menu__sub" href={child.href} data-mobile-link>{child.label}</a></li>
            ))}
          </>
        ))}
        <li><a href={cta.href} class="mobile-menu__cta" data-mobile-link>{cta.label}</a></li>
        <li>
          <button class="mobile-menu__theme" data-theme-toggle type="button" aria-label="Cambia tema">
            <span data-theme-text>Tema chiaro</span>
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: var(--z-header);
    padding-block: var(--sp-3);
  }
  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--sp-5);
    /* Full-bleed: nessun max-width, contenuto a filo bordi con solo il padding laterale */
    padding-inline: var(--container-pad);
  }
  .header__cta {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }

  /* Toggle tema desktop: pulsante tondo, icona sole (dark) / luna (light) */
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    color: var(--c-text-secondary);
    background: color-mix(in srgb, var(--c-bg) 65%, transparent);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-full);
    backdrop-filter: blur(14px);
    transition: color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  .theme-toggle:hover { color: var(--c-text); border-color: var(--c-line-strong); }
  .theme-toggle svg { width: 18px; height: 18px; }
  .theme-toggle__moon { display: none; }
  :root[data-theme='light'] .theme-toggle__sun { display: none; }
  :root[data-theme='light'] .theme-toggle__moon { display: block; }

  /* Pillola centrale: sfondo scuro translucido + blur, bordo tenue */
  .nav__list {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 0.35rem 0.6rem;
    background: color-mix(in srgb, var(--c-bg) 65%, transparent);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-full);
    backdrop-filter: blur(14px);
  }
  .nav__link {
    display: block;
    padding: 0.45rem 0.9rem;
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--c-text-secondary);
    border-radius: var(--radius-full);
    transition: color var(--dur-fast) var(--ease), background-color var(--dur-fast) var(--ease);
  }
  .nav__link:hover { color: var(--c-text); background: var(--c-surface-2); }

  /* Dropdown servizi: pannello sotto la voce, visibile su hover/focus */
  .nav__item { position: relative; }
  .nav__sub {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    translate: -50% 0;
    min-width: 200px;
    display: grid;
    padding: var(--sp-2);
    background: color-mix(in srgb, var(--c-bg) 88%, transparent);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-md);
    backdrop-filter: blur(14px);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--dur-fast) var(--ease), visibility var(--dur-fast) var(--ease);
  }
  .nav__item:hover .nav__sub,
  .nav__item:focus-within .nav__sub { opacity: 1; visibility: visible; }
  .nav__sublink {
    display: block;
    padding: var(--sp-2) var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--c-text-secondary);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease), background-color var(--dur-fast) var(--ease);
  }
  .nav__sublink:hover { color: var(--c-text); background: var(--c-surface-2); }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    justify-self: end;
    padding: var(--sp-2);
  }
  .burger span {
    width: 24px; height: 2px;
    background: var(--c-text);
    border-radius: 2px;
    transition: transform var(--dur) var(--ease), opacity var(--dur-fast) var(--ease);
  }
  .burger[aria-expanded='true'] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .burger[aria-expanded='true'] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    margin-top: var(--sp-2);
    margin-inline: var(--container-pad);
    background: color-mix(in srgb, var(--c-bg) 88%, transparent);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(14px);
    padding: var(--sp-4);
  }
  .mobile-menu ul { display: flex; flex-direction: column; gap: var(--sp-1); }
  .mobile-menu a {
    display: block;
    font-weight: var(--fw-medium);
    color: var(--c-text-secondary);
    padding: var(--sp-3) var(--sp-3);
    border-radius: var(--radius-md);
  }
  .mobile-menu a:hover { background: var(--c-surface-2); color: var(--c-text); }
  .mobile-menu__sub {
    margin-left: var(--sp-4);
    font-size: var(--fs-sm);
    color: var(--c-text-muted) !important;
  }
  .mobile-menu__cta {
    margin-top: var(--sp-2);
    text-align: center;
    color: var(--c-text) !important;
    border: 1px solid var(--c-line-strong);
    border-radius: var(--radius-full) !important;
  }
  .mobile-menu__theme {
    width: 100%;
    text-align: left;
    font-weight: var(--fw-medium);
    color: var(--c-text-secondary);
    padding: var(--sp-3) var(--sp-3);
    border-radius: var(--radius-md);
  }
  .mobile-menu__theme:hover { background: var(--c-surface-2); color: var(--c-text); }

  @media (max-width: 900px) {
    .nav, .header__cta { display: none; }
    .burger { display: flex; }
    .header__inner { grid-template-columns: 1fr auto; }
    /* header come piccolo banner nero (stile app) quando c'è il burger */
    .header {
      background: color-mix(in srgb, var(--c-bg) 86%, transparent);
      border-bottom: 1px solid var(--c-line);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }
  }
  @media (min-width: 901px) {
    .mobile-menu { display: none; }
  }
</style>

<script>
  // Toggle menu mobile. JS vanilla, zero dipendenze.
  const burger = document.querySelector('[data-burger]');
  const menu = document.querySelector('[data-mobile-menu]') as HTMLElement | null;

  const setMenu = (open: boolean) => {
    if (!burger || !menu) return;
    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Chiudi menu' : 'Apri menu');
    menu.hidden = !open;
  };

  burger?.addEventListener('click', () => {
    setMenu(burger.getAttribute('aria-expanded') !== 'true');
  });
  document.querySelectorAll('[data-mobile-link]').forEach((link) =>
    link.addEventListener('click', () => setMenu(false))
  );

  // Toggle tema (dark/light). Init già fatto in <head> per evitare il flash;
  // qui gestiamo click, persistenza e testo/aria dei bottoni.
  const currentTheme = () =>
    document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';

  const syncToggles = (theme: string) => {
    const label = theme === 'dark' ? 'Passa al tema chiaro' : 'Passa al tema scuro';
    document.querySelectorAll('[data-theme-toggle]').forEach((b) =>
      b.setAttribute('aria-label', label)
    );
    document.querySelectorAll('[data-theme-text]').forEach((s) => {
      s.textContent = theme === 'dark' ? 'Tema chiaro' : 'Tema scuro';
    });
  };

  const setTheme = (theme: string) => {
    document.documentElement.setAttribute('data-theme', theme);
    try { localStorage.setItem('theme', theme); } catch (e) {}
    syncToggles(theme);
  };

  syncToggles(currentTheme());
  document.querySelectorAll('[data-theme-toggle]').forEach((btn) =>
    btn.addEventListener('click', () => setTheme(currentTheme() === 'light' ? 'dark' : 'light'))
  );
</script>

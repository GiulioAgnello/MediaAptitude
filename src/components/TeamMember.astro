---
import type { TeamMember } from '../data/content';
interface Props { member: TeamMember; }
const { member } = Astro.props;
---

<article class="member">
  {member.photo ? (
    <img
      class="member__photo"
      src={member.photo.url}
      width={member.photo.width}
      height={member.photo.height}
      alt={member.photo.alt || member.name}
      loading="lazy"
      decoding="async"
    />
  ) : (
    <div class="member__avatar" aria-hidden="true">{member.initials}</div>
  )}
  <h3 class="member__name">{member.name}</h3>
  <p class="member__role">{member.role}</p>
  <ul class="member__skills" role="list">
    {member.skills.map((s) => <li>{s}</li>)}
  </ul>
</article>

<style>
  .member {
    text-align: center;
    padding: var(--sp-6) var(--sp-4);
    border-radius: var(--radius-lg);
    background: var(--c-surface);
    backdrop-filter: blur(8px);
    border: 1px solid var(--c-border);
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .member:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: color-mix(in srgb, var(--c-brand) 45%, transparent); }
  .member__avatar {
    width: 72px; height: 72px;
    margin: 0 auto var(--sp-4);
    display: grid; place-items: center;
    border-radius: var(--radius-full);
    background: linear-gradient(135deg, var(--c-brand), var(--c-accent));
    color: #fff;
    font-family: var(--font-heading);
    font-weight: var(--fw-bold);
    font-size: 1.4rem;
    letter-spacing: 0.02em;
  }
  .member__photo {
    width: 92px; height: 92px;
    margin: 0 auto var(--sp-4);
    display: block;
    object-fit: cover;
    border-radius: var(--radius-full);
    border: 2px solid color-mix(in srgb, var(--c-brand) 35%, transparent);
  }
  .member__name { font-size: var(--fs-lg); }
  .member__role { color: var(--c-brand); font-size: var(--fs-sm); font-weight: var(--fw-medium); margin-bottom: var(--sp-3); }
  .member__skills { display: flex; flex-wrap: wrap; justify-content: center; gap: var(--sp-2); }
  .member__skills li {
    font-size: var(--fs-xs);
    color: var(--c-text-muted);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-full);
    background: var(--c-bg-alt);
  }
</style>

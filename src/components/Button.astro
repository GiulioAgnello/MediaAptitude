---
/**
 * Bottone riutilizzabile. Renderizza <a> se passato href, altrimenti <button>.
 * Varianti (stile Cosmoq):
 *  - primary: pill scura con bordo-glow a gradiente ambra→blu
 *  - secondary: pill scura con bordo translucido
 *  - ghost: testuale, parola finale evidenziata in blu via <strong>
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  type?: 'button' | 'submit';
  class?: string;
}

const { href, variant = 'primary', type = 'button', class: extra } = Astro.props;
const Tag = href ? 'a' : 'button';
---

<Tag
  class:list={['btn', `btn--${variant}`, extra]}
  href={href}
  type={href ? undefined : type}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    font-family: var(--font-body);
    font-weight: var(--fw-medium);
    font-size: var(--fs-sm);
    padding: 0.8rem 1.6rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
    transition: transform var(--dur-fast) var(--ease),
      box-shadow var(--dur) var(--ease), background-color var(--dur) var(--ease),
      border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .btn:hover { transform: translateY(-2px); }
  .btn:active { transform: translateY(0); }

  /* Primario: doppio background border-box = bordo a gradiente ambra→blu,
     interno quasi nero. Il glow esterno arriva dalle due ombre colorate. */
  .btn--primary {
    color: var(--c-pill-text);
    border: 1px solid transparent;
    background:
      linear-gradient(var(--c-pill-bg), var(--c-pill-bg)) padding-box,
      linear-gradient(100deg, var(--c-amber), rgba(255, 255, 255, 0.25), var(--c-blue)) border-box;
    box-shadow:
      -6px 0 18px -6px rgba(255, 172, 10, 0.45),
      6px 0 18px -6px rgba(77, 141, 255, 0.5);
  }
  .btn--primary:hover {
    box-shadow:
      -8px 0 26px -6px rgba(255, 172, 10, 0.6),
      8px 0 26px -6px rgba(77, 141, 255, 0.65);
  }

  .btn--secondary {
    color: var(--c-text-secondary);
    background: var(--c-surface);
    border: 1px solid var(--c-line);
  }
  .btn--secondary:hover {
    border-color: var(--c-line-strong);
    background: var(--c-surface-2);
    color: var(--c-text);
  }

  .btn--ghost {
    padding-inline: 0;
    color: var(--c-text-secondary);
    background: transparent;
  }
  .btn--ghost:hover { color: var(--c-blue); }
</style>

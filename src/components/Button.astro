---
/**
 * Bottone riutilizzabile. Renderizza <a> se passato href, altrimenti <button>.
 * Varianti: primary | secondary | ghost.
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  type?: 'button' | 'submit';
  class?: string;
}

const { href, variant = 'primary', type = 'button', class: extra } = Astro.props;
const Tag = href ? 'a' : 'button';
---

<Tag
  class:list={['btn', `btn--${variant}`, extra]}
  href={href}
  type={href ? undefined : type}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    font-family: var(--font-heading);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-sm);
    letter-spacing: 0.02em;
    padding: 0.75rem 1.4rem;
    border-radius: var(--radius-full);
    transition: transform var(--dur-fast) var(--ease),
      box-shadow var(--dur) var(--ease), background-color var(--dur) var(--ease),
      color var(--dur) var(--ease);
    white-space: nowrap;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn:active { transform: translateY(0); }

  .btn--primary {
    background-color: var(--c-brand);
    color: #fff;
    box-shadow: var(--shadow-brand);
  }
  .btn--primary:hover { background-color: var(--c-brand-dark); }

  .btn--secondary {
    background-color: var(--c-ink-900);
    color: #fff;
  }
  .btn--secondary:hover { background-color: var(--c-ink-700); }

  .btn--ghost {
    background-color: transparent;
    color: var(--c-text);
    border: 1px solid var(--c-border);
  }
  .btn--ghost:hover { border-color: var(--c-brand); color: var(--c-brand); }
</style>

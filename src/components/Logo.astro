---
/** Logo testuale Media Aptitude. Inline SVG-free, leggero e nitido. */
import { site } from '../data/site';
interface Props { variant?: 'dark' | 'light'; }
const { variant = 'dark' } = Astro.props;
---

<a href="/" class:list={['logo', `logo--${variant}`]} aria-label={`${site.name} — home`}>
  <span class="logo__mark" aria-hidden="true">
    <svg viewBox="0 0 32 32" width="28" height="28" fill="none">
      <rect x="2" y="2" width="28" height="28" rx="8" fill="var(--c-brand)" />
      <path d="M9 22V11l7 6 7-6v11" stroke="#fff" stroke-width="2.4"
        stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
  <span class="logo__text">
    Media<span class="logo__accent">Aptitude</span>
  </span>
</a>

<style>
  .logo { display: inline-flex; align-items: center; gap: var(--sp-2); }
  .logo__mark { display: inline-flex; }
  .logo__text {
    font-family: var(--font-heading);
    font-weight: var(--fw-bold);
    font-size: 1.3rem;
    letter-spacing: -0.01em;
    color: var(--c-text);
  }
  .logo__accent { color: var(--c-brand); }
  .logo--light .logo__text { color: #fff; }
  .logo--light .logo__accent { color: var(--c-accent); }
</style>
